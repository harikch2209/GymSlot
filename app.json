{
  "expo": {
    "name": "GymSlot",
    "slug": "gymslot-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "gymslot",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "primaryColor": "#10B981",
    "description": "Pay-per-slot gym booking. Book a 30 or 60-minute session at gyms near you, see live crowd levels, add a trainer, and pay only for what you use.",
    "githubUrl": "https://github.com/harikch2209/GymSlot",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gymslot.mobile",
      "buildNumber": "1",
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "CFBundleDisplayName": "GymSlot",
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "GymSlot uses your location to show gyms near you and how far away they are."
      }
    },
    "android": {
      "package": "com.gymslot.mobile",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "monochromeImage": "./assets/notification-icon.png",
        "backgroundColor": "#10B981"
      },
      "permissions": [
        "INTERNET",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ],
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "GymSlot uses your location to show gyms near you and how far away they are."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "GymSlot uses the camera so gym partners can scan member QR tickets to check them in."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 180,
          "resizeMode": "contain",
          "backgroundColor": "#FFFFFF",
          "dark": {
            "backgroundColor": "#0E1116"
          }
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 24,
            "kotlinVersion": "1.9.25"
          },
          "ios": {
            "deploymentTarget": "15.1"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "d83b70bd-1a29-4fb6-88bc-7d100efaec02"
      }
    },
    "owner": "harikch2209"
  }
}
