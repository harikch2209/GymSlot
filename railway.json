{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "phases": {
        "install": { "cmds": ["npm install --include=dev"] }
      }
    }
  },
  "deploy": {
    "startCommand": "npm run cloud:dev",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
