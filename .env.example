# Copy to .env. Find these in Supabase dashboard → Project Settings → Data API / API Keys.
# The anon (publishable) key is safe to expose in the client; Row Level Security
# enforces what it can actually read or write.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key
# Razorpay test Key ID (the Key Secret goes in the Supabase Edge Function secret, not here)
EXPO_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx

# Google Maps key for STANDALONE ANDROID builds only (not needed for Expo Go / iOS).
# Read by app.config.js. For EAS builds, set it as an EAS secret instead of committing it:
#   eas secret:create --scope project --name GOOGLE_MAPS_ANDROID_KEY --value <key>
GOOGLE_MAPS_ANDROID_KEY=
