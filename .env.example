# Copy to .env. Find these in Supabase dashboard → Project Settings → Data API / API Keys.
# The anon (publishable) key is safe to expose in the client; Row Level Security
# enforces what it can actually read or write.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key
